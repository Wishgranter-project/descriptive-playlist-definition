{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wishgranterproject.com/schemas/playlist.json",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "The playlist's title."
    },
    "description": {
      "type": "string",
      "description": "An observation about the playlist contents."
    }
  },
  "patternProperties": {
    "^xxx[A-Za-z0-9]{1,100}$": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      ]
    }
  }
}